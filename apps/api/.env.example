# Environment used by `pnpm --filter @edb/api dev` (host dev outside Docker).
# Copy to `apps/api/.env` and adjust if needed:
#   cp apps/api/.env.example apps/api/.env
#
# For `docker compose up`, you can ignore this file — the compose stack has
# its own defaults baked in (see root .env.example for compose-side overrides).

DATABASE_URL=postgresql://edbhub:changeme_in_dev@localhost:5432/edbhub
REDIS_URL=redis://localhost:6379

API_PORT=3000
SESSION_TTL_SECONDS=28800
SESSION_COOKIE_NAME=edb_sid
WEB_ORIGIN=http://localhost:5173

ADMIN_EMAIL=admin@escoladobreno.test
ADMIN_PASSWORD=AdminTest123!
