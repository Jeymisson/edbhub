{
  "name": "edbhub",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "dev:infra": "docker compose -f docker-compose.yml -f compose.dev.yml up -d db redis",
    "dev:infra:down": "docker compose -f docker-compose.yml -f compose.dev.yml down",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint apps packages"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.4"
  }
}
